# ─── Postgres ─────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_db_password

# ─── Security ─────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=changeme_generate_a_real_secret_here

# ─── Initial admin account (used by seed script on first boot) ────────────
INITIAL_ADMIN_EMAIL=admin@dark-factory.local
INITIAL_ADMIN_PASSWORD=ChangeMe123!

# ─── OpenAI ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─── Ticket Manager integration ───────────────────────────────────────────
TICKET_MANAGER_BASE_URL=https://ticket-manager.dark-factory.miveralta.ru
# Service account credentials (must exist in your Ticket Manager instance)
TICKET_MANAGER_SERVICE_EMAIL=service@dark-factory.local
TICKET_MANAGER_SERVICE_PASSWORD=changeme_tm_password

# ─── Networking ───────────────────────────────────────────────────────────
HTTP_PORT=80
