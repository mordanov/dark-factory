# Dark Factory Platform — Environment Configuration
# Copy this file to .env and fill in all required values.
# NEVER commit .env to git. This file (.env.example) is safe to commit.
#
# Usage:
#   cp infra/.env.example infra/.env
#   # Fill in POSTGRES_PASSWORD, KC_BOOTSTRAP_ADMIN_PASSWORD, all KC_*_CLIENT_SECRET
#   # values, OAUTH2_PROXY_* values, and OPENAI_API_KEY
#   docker compose -f infra/docker-compose.yml up --build

# ─────────────────────────────────────────────────────────────────────────────
# Group 1: PostgreSQL Shared
# Used by: postgres container (init) and all backend services
# ─────────────────────────────────────────────────────────────────────────────

# Superuser for postgres init scripts (creates per-service databases and users)
POSTGRES_USER=postgres

# REQUIRED: Postgres superuser password — change before deploying
POSTGRES_PASSWORD=changeme

# Internal postgres hostname (matches service name in compose)
POSTGRES_HOST=postgres

# PostgreSQL port — default 5432
POSTGRES_PORT=5432

# ─────────────────────────────────────────────────────────────────────────────
# Group 2: MongoDB Shared
# Used by: orchestrator, context-distiller
# ─────────────────────────────────────────────────────────────────────────────

# Internal MongoDB hostname (matches service name in compose)
MONGO_HOST=mongo

# MongoDB port — default 27017
MONGO_PORT=27017

# ─────────────────────────────────────────────────────────────────────────────
# Group 3: user-input-manager (Prompt Studio)
# Used by: user-input-manager backend service
# ─────────────────────────────────────────────────────────────────────────────

# Dedicated PostgreSQL user for df_user_input database
UIM_DB_USER=uim_user

# REQUIRED: Password for the UIM postgres user
UIM_DB_PASSWORD=changeme_uim

# Internal URL of ticket-manager service (for UIM→TM API calls)
# Internal port is 8000 (host port 8002 is only in docker-compose.override.yml)
UIM_TM_URL=http://ticket-manager:8000

# ─────────────────────────────────────────────────────────────────────────────
# Group 4: ticket-manager
# Used by: ticket-manager backend service
# ─────────────────────────────────────────────────────────────────────────────

# Dedicated PostgreSQL user for df_ticket_manager database
TM_DB_USER=tm_user

# REQUIRED: Password for the TM postgres user
TM_DB_PASSWORD=changeme_tm

# ─────────────────────────────────────────────────────────────────────────────
# Group 5: orchestrator
# Used by: orchestrator service
# ─────────────────────────────────────────────────────────────────────────────

# Dedicated PostgreSQL user for df_orchestrator database
ORCH_DB_USER=orch_user

# REQUIRED: Password for the orchestrator postgres user
ORCH_DB_PASSWORD=changeme_orch

# MongoDB database name for orchestrator (default: df_orchestrator_docs)
ORCH_MONGO_DB=df_orchestrator_docs

# ─────────────────────────────────────────────────────────────────────────────
# Group 6: context-distiller
# Used by: context-distiller service
# ─────────────────────────────────────────────────────────────────────────────

# Dedicated PostgreSQL user for df_distiller database
DISTILLER_DB_USER=distiller_user

# REQUIRED: Password for the context-distiller postgres user
DISTILLER_DB_PASSWORD=changeme_distiller

# MongoDB database name for context-distiller (default: df_distiller_docs)
DISTILLER_MONGO_DB=df_distiller_docs

# ─────────────────────────────────────────────────────────────────────────────
# Group 7: agent-tools
# Used by: agent-tools service
# ─────────────────────────────────────────────────────────────────────────────

# (No additional database for agent-tools — auth handled via Keycloak)

# ─────────────────────────────────────────────────────────────────────────────
# Group 8: Nginx / DNS
# Used by: nginx service (envsubst at container startup)
# ─────────────────────────────────────────────────────────────────────────────

# DNS hostname for Prompt Studio (user-input-manager frontend)
# Local dev: use studio.dark-factory.local (add to /etc/hosts)
# Production: your actual domain
UIM_HOST=studio.dark-factory.local

# DNS hostname for Ticket Manager frontend
# Local dev: use tickets.dark-factory.local (add to /etc/hosts)
TM_HOST=tickets.dark-factory.local

# HTTP port exposed on the host (nginx listens on this port)
HTTP_PORT=80

# ─────────────────────────────────────────────────────────────────────────────
# Group 9: Keycloak IAM (sole identity provider — §XVII)
# Used by: keycloak container + all 6 backend services + both frontends
# ─────────────────────────────────────────────────────────────────────────────

# Keycloak database user (for df_keycloak database; created by postgres init)
KC_DB_USERNAME=keycloak_user

# REQUIRED: Password for the Keycloak postgres user
KC_DB_PASSWORD=changeme_kc_db

# Keycloak hostname — how nginx/external clients reach Keycloak
# Use 'localhost' for local dev (accessed via http://localhost:8080)
# Use your public domain in production
KC_HOSTNAME=localhost

# Keycloak bootstrap admin username (used at first boot; change password on login)
KC_BOOTSTRAP_ADMIN_USERNAME=admin

# REQUIRED: Keycloak bootstrap admin initial password — change on first login
KC_BOOTSTRAP_ADMIN_PASSWORD=changeme_kc_admin

# Keycloak bootstrap admin email
KC_BOOTSTRAP_ADMIN_EMAIL=admin@dark-factory.local

# ─────────────────────────────────────────────────────────────────────────────
# Group 10: oauth2-proxy
# Used by: oauth2-proxy container (Bearer token validation at nginx boundary)
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED: oauth2-proxy Keycloak client secret — must match realm 'oauth2-proxy' client secret
OAUTH2_PROXY_CLIENT_SECRET=changeme_oauth2_proxy

# REQUIRED: oauth2-proxy cookie signing secret — must be exactly 32 random bytes (base64)
# Generate with: python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
OAUTH2_PROXY_COOKIE_SECRET=changeme-32-bytes-base64-encoded!!

# ─────────────────────────────────────────────────────────────────────────────
# Group 11: Service Client Secrets (confidential Keycloak clients)
# Used by: each backend service to obtain service-to-service tokens via Client Credentials
# All must match values in the realm-export.json (or be set via Admin Console)
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED: orchestrator service account client secret
KC_ORCHESTRATOR_CLIENT_SECRET=changeme_orch_kc

# REQUIRED: context-distiller service account client secret
KC_DISTILLER_CLIENT_SECRET=changeme_distiller_kc

# REQUIRED: agent-dispatcher service account client secret
KC_DISPATCHER_CLIENT_SECRET=changeme_dispatcher_kc

# REQUIRED: agent-tools service account client secret
KC_AGENT_TOOLS_CLIENT_SECRET=changeme_agent_tools_kc

# REQUIRED: user-input-manager service account client secret
KC_UIM_CLIENT_SECRET=changeme_uim_kc

# REQUIRED: ticket-manager service account client secret
KC_TM_CLIENT_SECRET=changeme_tm_kc

# ─────────────────────────────────────────────────────────────────────────────
# Group 12: Google OIDC (disabled by default)
# Used by: Keycloak realm Google identity provider placeholder
# Enable by setting both values and toggling 'enabled: true' in Keycloak Admin Console
# ─────────────────────────────────────────────────────────────────────────────

# Google OAuth2 client ID (leave empty to keep Google IdP disabled)
GOOGLE_CLIENT_ID=

# Google OAuth2 client secret (leave empty to keep Google IdP disabled)
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Group 13: Frontend URLs (Keycloak redirect URI allowlist)
# Used by: Keycloak realm client registrations (uim-frontend, tm-frontend)
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of UIM frontend (used in Keycloak redirect URI: "${UIM_FRONTEND_URL}/*")
# Local dev: http://localhost:5173 (Vite dev server) or http://studio.dark-factory.local
UIM_FRONTEND_URL=http://localhost:5173

# Base URL of TM frontend
# Local dev: http://localhost:5174 (Vite dev server) or http://tickets.dark-factory.local
TM_FRONTEND_URL=http://localhost:5174

# ─────────────────────────────────────────────────────────────────────────────
# Group 14: Frontend Vite environment vars
# These are NOT set here — each frontend service has its own .env.example:
#   services/user-input-manager/frontend/.env.example
#   services/ticket-manager/frontend/.env.example
#
# Each service sets VITE_KEYCLOAK_URL, VITE_KEYCLOAK_REALM, VITE_KEYCLOAK_CLIENT_ID
# independently. VITE_KEYCLOAK_CLIENT_ID differs per frontend (uim-frontend vs tm-frontend).
#
# For reference only (values to match in each service .env):
#   VITE_KEYCLOAK_URL=http://localhost:8080   (must match KC_HOSTNAME accessible from browser)
#   VITE_KEYCLOAK_REALM=dark-factory
#   VITE_KEYCLOAK_CLIENT_ID=uim-frontend      (UIM) or tm-frontend (TM)
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# Group 15: OpenAI / LLM
# Used by: user-input-manager, orchestrator, context-distiller
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED: OpenAI API key (or any value when running integration tests with LLM mock)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Override LLM base URL (used in integration tests to point to llm-mock)
# Leave empty in production. Set to http://llm-mock:11434/v1 for integration tests.
OPENAI_BASE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Group 16: agent-dispatcher
# Used by: agent-dispatcher service and postgres init (creates df_dispatcher DB)
# ─────────────────────────────────────────────────────────────────────────────

# Dedicated PostgreSQL user for df_dispatcher database
DISPATCHER_DB_USER=dispatcher_user

# REQUIRED: Password for the agent-dispatcher postgres user
DISPATCHER_DB_PASSWORD=changeme_dispatcher

# Internal URL of the Orchestrator service (for polling pending-tickets endpoint)
DISPATCHER_ORCHESTRATOR_URL=http://orchestrator:8000

# Internal URL of the Ticket Manager service (for posting run results as comments)
DISPATCHER_TM_URL=http://ticket-manager:8000

# Internal URL of the Context Distiller service (for project memory, ADRs, agent config)
DISPATCHER_DISTILLER_URL=http://context-distiller:8000

# Agent runner mode: 'claude_code' (subprocess) or 'api' (OpenAI API call)
# Use 'claude_code' when running with full Claude Code access on the host.
# Use 'api' for lightweight container deployments without Claude CLI installed.
AGENT_RUNNER_MODE=claude_code

# Directory containing agent system prompt files (one .md file per agent_id)
# Prompts are read from disk on every run — no restart needed after edits.
AGENT_PROMPTS_DIR=/app/prompts

# Path to the agent capability registry YAML file inside the container.
# The registry is mounted read-only from development/agents/registry.yaml via docker-compose.
# Changes to registry.yaml require a service restart to take effect (loaded once at startup).
# Used by: agent-dispatcher
AGENT_REGISTRY_PATH=/app/registry.yaml

# How often (seconds) the dispatcher polls the Orchestrator for new assignments
POLL_INTERVAL_SECONDS=10

# Maximum number of agent runs that may execute concurrently (semaphore limit)
WORKER_MAX_CONCURRENT_RUNS=3

# Default agent execution timeout in seconds (applies to all agents unless overridden)
AGENT_TIMEOUT_DEFAULT=300

# Per-agent timeout overrides — uncomment and set as needed.
# Override format: AGENT_TIMEOUT_{AGENT_ID_UPPER}=<seconds>
# Example: backend agent gets 600s, software_architect gets 900s
# AGENT_TIMEOUT_BACKEND=600
# AGENT_TIMEOUT_SOFTWARE_ARCHITECT=900
# AGENT_TIMEOUT_SECURITY_ARCHITECT=900
# AGENT_TIMEOUT_FRONTEND=600

# Maximum number of brainstorm rounds before session concludes with disagreed
BRAINSTORM_MAX_ROUNDS=3

# Comma-separated list of agent IDs participating in brainstorm sessions (in order)
# Must use hyphenated role IDs matching registry.yaml (e.g. software-architect, not software_architect)
BRAINSTORM_AGENTS=software-architect,security-architect

# ─── Brainstorm MCP ──────────────────────────────────────────────────────
# Path to the brainstorm-mcp installation (where package.json lives)
# Run `which brainstorm-messages` or check your MCP config to find this.
BRAINSTORM_NPX_PREFIX=~/.local/share/brainstorm-mcp

# Timeout for reading brainstorm session messages via CLI (seconds)
BRAINSTORM_CLI_TIMEOUT_SECONDS=30

# Maximum approximate token count for injected project memory context (word-based estimate)
CONTEXT_MAX_TOKENS=6000

# OpenAI model to use in 'api' runner mode (ignored when AGENT_RUNNER_MODE=claude_code)
OPENAI_MODEL=gpt-4o

# Path to claude CLI binary (used by 'claude_code' runner mode only)
# CLAUDE_CODE_PATH=/usr/local/bin/claude

# Path to MCP config JSON for claude CLI (used in 'claude_code' mode for brainstorm MCP)
# CLAUDE_MCP_CONFIG_PATH=/root/.claude/mcp_config.json

# ─────────────────────────────────────────────────────────────────────────────
# Group 17: Planning Agent (user-input-manager)
# Used by: user-input-manager backend service (planning feature)
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI model used for agent-config generation (cheaper model is fine here)
# Plan generation uses OPENAI_MODEL (Group 15); this controls only the second LLM call.
PLANNING_MODEL=gpt-4o-mini

# Internal URL of the ContextDistiller service — must be reachable from user-input-manager
# agent-config is stored here after successful ticket creation (best-effort, never blocks)
CONTEXT_DISTILLER_BASE_URL=http://context-distiller:8000

# Timeout in seconds for the ContextDistiller HTTP call from user-input-manager
# Failure is logged and silently ignored; increase only if ContextDistiller is slow
CONTEXT_DISTILLER_TIMEOUT_SECONDS=10
