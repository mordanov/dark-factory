# Dark Factory Platform — Environment Configuration
# Copy this file to .env and fill in all required values.
# NEVER commit .env to git. This file (.env.example) is safe to commit.
#
# Usage:
#   cp infra/.env.example infra/.env
#   # Fill in POSTGRES_PASSWORD, all SECRET_KEY values, and OPENAI_API_KEY
#   docker compose -f infra/docker-compose.yml up --build

# ─────────────────────────────────────────────────────────────────────────────
# Group 1: PostgreSQL Shared
# Used by: postgres container (init) and all backend services
# ─────────────────────────────────────────────────────────────────────────────

# Superuser for postgres init scripts (creates per-service databases and users)
POSTGRES_USER=postgres

# REQUIRED: Postgres superuser password — change before deploying
POSTGRES_PASSWORD=changeme

# Internal postgres hostname (matches service name in compose)
POSTGRES_HOST=postgres

# PostgreSQL port — default 5432
POSTGRES_PORT=5432

# ─────────────────────────────────────────────────────────────────────────────
# Group 2: MongoDB Shared
# Used by: orchestrator, context-distiller
# ─────────────────────────────────────────────────────────────────────────────

# Internal MongoDB hostname (matches service name in compose)
MONGO_HOST=mongo

# MongoDB port — default 27017
MONGO_PORT=27017

# ─────────────────────────────────────────────────────────────────────────────
# Group 3: user-input-manager (Prompt Studio)
# Used by: user-input-manager backend service
# ─────────────────────────────────────────────────────────────────────────────

# Dedicated PostgreSQL user for df_user_input database
UIM_DB_USER=uim_user

# REQUIRED: Password for the UIM postgres user
UIM_DB_PASSWORD=changeme_uim

# REQUIRED: JWT signing secret for UIM — use a long random string (32+ chars)
UIM_SECRET_KEY=change-me-uim-secret-key-min-32-chars

# Auth mode: 'local' (JWT via local DB) or 'keycloak' (stub — returns 501)
UIM_AUTH_MODE=local

# Internal URL of ticket-manager service (for UIM→TM API calls)
# Internal port is 8000 (host port 8002 is only in docker-compose.override.yml)
UIM_TM_URL=http://ticket-manager:8000

# Service account used by UIM and orchestrator to call ticket-manager on behalf of user
# Must match a TM user with sufficient permissions (e.g. admin or dedicated service role)
TM_SERVICE_EMAIL=service@dark-factory.local
TM_SERVICE_PASSWORD=changeme_service

# Initial admin user seeded by UIM on first boot (env-driven per FR-016)
UIM_ADMIN_EMAIL=admin@dark-factory.local
UIM_ADMIN_PASSWORD=changeme_uim_admin

# ─────────────────────────────────────────────────────────────────────────────
# Group 4: ticket-manager
# Used by: ticket-manager backend service
# ─────────────────────────────────────────────────────────────────────────────

# Dedicated PostgreSQL user for df_ticket_manager database
TM_DB_USER=tm_user

# REQUIRED: Password for the TM postgres user
TM_DB_PASSWORD=changeme_tm

# REQUIRED: JWT signing secret for ticket-manager — use a long random string
# Note: TM config.py uses field name 'secret_key' (pydantic maps to env var SECRET_KEY)
TM_SECRET_KEY=change-me-tm-secret-key-min-32-chars

# REQUIRED: Separate refresh-token signing secret for ticket-manager (32+ chars)
TM_REFRESH_SECRET=change-me-tm-refresh-secret-32-chars!!

# Initial admin/user seeded by TM on first boot (env-driven per FR-016)
TM_ADMIN_EMAIL=admin@tickets.dark-factory.local
TM_ADMIN_PASSWORD=changeme_tm_admin
TM_USER_EMAIL=user@tickets.dark-factory.local
TM_USER_PASSWORD=changeme_tm_user

# Auth mode: 'local' or 'keycloak'
TM_AUTH_MODE=local

# ─────────────────────────────────────────────────────────────────────────────
# Group 5: orchestrator
# Used by: orchestrator service
# ─────────────────────────────────────────────────────────────────────────────

# Dedicated PostgreSQL user for df_orchestrator database
ORCH_DB_USER=orch_user

# REQUIRED: Password for the orchestrator postgres user
ORCH_DB_PASSWORD=changeme_orch

# REQUIRED: JWT signing secret for orchestrator
ORCH_SECRET_KEY=change-me-orch-secret-key-min-32-chars

# Auth mode: 'local' or 'keycloak'
ORCH_AUTH_MODE=local

# MongoDB database name for orchestrator (default: df_orchestrator_docs)
ORCH_MONGO_DB=df_orchestrator_docs

# ─────────────────────────────────────────────────────────────────────────────
# Group 6: context-distiller
# Used by: context-distiller service
# ─────────────────────────────────────────────────────────────────────────────

# Dedicated PostgreSQL user for df_distiller database
DISTILLER_DB_USER=distiller_user

# REQUIRED: Password for the context-distiller postgres user
DISTILLER_DB_PASSWORD=changeme_distiller

# REQUIRED: JWT signing secret for context-distiller
DISTILLER_SECRET_KEY=change-me-distiller-secret-key-min-32-chars

# Auth mode: 'local' or 'keycloak'
DISTILLER_AUTH_MODE=local

# MongoDB database name for context-distiller (default: df_distiller_docs)
DISTILLER_MONGO_DB=df_distiller_docs

# ─────────────────────────────────────────────────────────────────────────────
# Group 7: agent-tools
# Used by: agent-tools service
# ─────────────────────────────────────────────────────────────────────────────

# Auth mode: 'local' or 'keycloak'
AGENT_TOOLS_AUTH_MODE=local

# REQUIRED: JWT secret for agent-tools (min 32 chars)
AGENT_TOOLS_SECRET_KEY=change-me-agent-tools-secret-32-chars!!

# ─────────────────────────────────────────────────────────────────────────────
# Group 8: Nginx / DNS
# Used by: nginx service (envsubst at container startup)
# ─────────────────────────────────────────────────────────────────────────────

# DNS hostname for Prompt Studio (user-input-manager frontend)
# Local dev: use studio.dark-factory.local (add to /etc/hosts)
# Production: your actual domain
UIM_HOST=studio.dark-factory.local

# DNS hostname for Ticket Manager frontend
# Local dev: use tickets.dark-factory.local (add to /etc/hosts)
TM_HOST=tickets.dark-factory.local

# HTTP port exposed on the host (nginx listens on this port)
HTTP_PORT=80

# ─────────────────────────────────────────────────────────────────────────────
# Group 9: Auth Adapter (Keycloak — stub only in this release)
# Not used in AUTH_MODE=local (default). Present for future Keycloak integration.
# ─────────────────────────────────────────────────────────────────────────────

# Keycloak JWKS endpoint — only read when AUTH_MODE=keycloak
# KEYCLOAK_JWKS_URL=https://keycloak.example.com/realms/dark-factory/protocol/openid-connect/certs

# ─────────────────────────────────────────────────────────────────────────────
# Group 10: OpenAI / LLM
# Used by: user-input-manager, orchestrator, context-distiller
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED: OpenAI API key (or any value when running integration tests with LLM mock)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Override LLM base URL (used in integration tests to point to llm-mock)
# Leave empty in production. Set to http://llm-mock:11434/v1 for integration tests.
OPENAI_BASE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Group 11: agent-dispatcher
# Used by: agent-dispatcher service and postgres init (creates df_dispatcher DB)
# ─────────────────────────────────────────────────────────────────────────────

# Dedicated PostgreSQL user for df_dispatcher database
DISPATCHER_DB_USER=dispatcher_user

# REQUIRED: Password for the agent-dispatcher postgres user
DISPATCHER_DB_PASSWORD=changeme_dispatcher

# REQUIRED: JWT signing secret for agent-dispatcher — use a long random string (32+ chars)
DISPATCHER_SECRET_KEY=change-me-dispatcher-secret-key-min-32-chars

# Auth mode: 'local' (JWT via local DB) or 'keycloak' (stub — returns 501)
DISPATCHER_AUTH_MODE=local

# Internal URL of the Orchestrator service (for polling pending-tickets endpoint)
DISPATCHER_ORCHESTRATOR_URL=http://orchestrator:8000

# Internal URL of the Ticket Manager service (for posting run results as comments)
DISPATCHER_TM_URL=http://ticket-manager:8000

# Internal URL of the Context Distiller service (for project memory, ADRs, agent config)
DISPATCHER_DISTILLER_URL=http://context-distiller:8000

# Agent runner mode: 'claude_code' (subprocess) or 'api' (OpenAI API call)
# Use 'claude_code' when running with full Claude Code access on the host.
# Use 'api' for lightweight container deployments without Claude CLI installed.
AGENT_RUNNER_MODE=claude_code

# Directory containing agent system prompt files (one .md file per agent_id)
# Prompts are read from disk on every run — no restart needed after edits.
AGENT_PROMPTS_DIR=/app/prompts

# How often (seconds) the dispatcher polls the Orchestrator for new assignments
POLL_INTERVAL_SECONDS=10

# Maximum number of agent runs that may execute concurrently (semaphore limit)
WORKER_MAX_CONCURRENT_RUNS=3

# Default agent execution timeout in seconds (applies to all agents unless overridden)
AGENT_TIMEOUT_DEFAULT=300

# Per-agent timeout overrides — uncomment and set as needed.
# Override format: AGENT_TIMEOUT_{AGENT_ID_UPPER}=<seconds>
# Example: backend agent gets 600s, software_architect gets 900s
# AGENT_TIMEOUT_BACKEND=600
# AGENT_TIMEOUT_SOFTWARE_ARCHITECT=900
# AGENT_TIMEOUT_SECURITY_ARCHITECT=900
# AGENT_TIMEOUT_FRONTEND=600

# Maximum number of brainstorm rounds before session concludes with disagreed
BRAINSTORM_MAX_ROUNDS=3

# Comma-separated list of agent IDs participating in brainstorm sessions (in order)
BRAINSTORM_AGENTS=software_architect,security_architect

# Maximum approximate token count for injected project memory context (word-based estimate)
CONTEXT_MAX_TOKENS=6000

# OpenAI model to use in 'api' runner mode (ignored when AGENT_RUNNER_MODE=claude_code)
OPENAI_MODEL=gpt-4o

# Path to claude CLI binary (used by 'claude_code' runner mode only)
# CLAUDE_CODE_PATH=/usr/local/bin/claude

# Path to MCP config JSON for claude CLI (used in 'claude_code' mode for brainstorm MCP)
# CLAUDE_MCP_CONFIG_PATH=/root/.claude/mcp_config.json
