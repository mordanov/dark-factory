# ─── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_db_password

# ─── MongoDB ──────────────────────────────────────────────────────────────
# (no credentials needed for local dev; add auth for production)

# ─── JWT (must match Prompt Studio JWT_SECRET_KEY exactly) ────────────────
JWT_SECRET_KEY=changeme_same_as_prompt_studio

# ─── OpenAI ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─── Ticket Manager ───────────────────────────────────────────────────────
TICKET_MANAGER_BASE_URL=https://ticket-manager.dark-factory.miveralta.ru
TICKET_MANAGER_SERVICE_EMAIL=service@dark-factory.local
TICKET_MANAGER_SERVICE_PASSWORD=changeme_tm_password

# ─── Worker ───────────────────────────────────────────────────────────────
WORKER_MAX_CONCURRENT_TICKETS=5

# ─── Networking ───────────────────────────────────────────────────────────
# Orchestrator runs on a different port from Prompt Studio (default 80)
HTTP_PORT=8080
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost
